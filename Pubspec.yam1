name: homafloods_customer
description: Homa Bay delivery
version: 1.0.0+1
environment:
  sdk: '>=3.0.0 <4.0.0'

dependencies:
  flutter:
    sdk: flutter
  firebase_core: ^2.24.2
  cloud_firestore: ^4.13.6
  firebase_auth: ^4.15.3
  firebase_messaging: ^14.7.10
  intasend_flutter: ^2.3.0
  geolocator: ^10.1.0
  google_maps_flutter: ^2.5.0
  geoflutterfire2: ^2.3.15

flutter:
  uses-material-design: true
